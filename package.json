{
  "name": "@yuexiaoliang1993/essh",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.25.0",
  "description": "",
  "author": "岳晓亮 <hi@yuexiaoliang.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/yuexiaoliang",
  "homepage": "https://github.com/yuexiaoliang/essh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuexiaoliang/essh.git"
  },
  "bugs": "https://github.com/yuexiaoliang/essh/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "essh": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "age-encryption": "catalog:",
    "chalk": "catalog:",
    "commander": "catalog:",
    "fs-extra": "catalog:",
    "inquirer": "catalog:",
    "simple-git": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@types/fs-extra": "catalog:",
    "@types/inquirer": "catalog:",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tinyexec": "catalog:testing",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing",
    "vitest-package-exports": "catalog:testing",
    "yaml": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "publishConfig": {
    "access": "public"
  }
}
